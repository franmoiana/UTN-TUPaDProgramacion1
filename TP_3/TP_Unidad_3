    if alarma == True:
        print()
        print("La alarma se encuentra activada!")
        print()
    if alarma == True and tiempo <= 3 and cerraduras_abiertas < 3:
        print()
        print("Su tiempo se agoto!")
        print("Sistema bloqueado. Fin del juego")
        break
    elif cerraduras_abiertas == 3:
        print()
        print("Boveda desbloqueada. Has ganado el juego")
        print()
        break
    elif energia <= 0 or tiempo <= 0:
        if energia <= 0:
            print("Fin del juego. Tu energia se agoto")
            break
        elif tiempo <= 0:
            print("Fin del juego. Tu tiempo se agoto")
            break
    elif forzar_seguidas == 3:
        alarma = True
    print()
    print("Seleccione una de las siguientes acciones")
    print()
    print("1. Forzar cerradura (costo: -20 energia y -2 de tiempo)")
    print("2. Hackear panel (costo: -10 energía, -3 tiempo)")
    print("3. Descansar")
    print()
    opcion = input("Introduzca la accion a realizar: ")
    if opcion.isdigit():
        opcion = int(opcion)
        if opcion <= 3 and opcion > 0:
            match opcion:
                case 1:
                    if energia < 40:
                        print()
                        print("Su energia es menor a 40! Riesgo de alarma activado!")
                        print()
                        print("Seleccione un numero del 1 al 3")
                        while True:
                            numero_energia = input("Ingrese su numero: ")
                            if numero_energia.isdigit():
                                numero_energia = int(numero_energia)
                                if numero_energia <= 3 and numero_energia > 0:
                                    break
                                else:
                                    print("Ingrese un numero del 1 al 3.")
                            else:
                                print("Solo se permiten numeros.")
                        if numero_energia == 3:
                            alarma = True
                            print()
                            print("ALARMA ACTIVADA")
                        elif alarma == False:
                            cerraduras_abiertas += 1
                            energia -= 20 
                            tiempo -= 2
                            forzar_seguidas += 1
                    elif forzar_seguidas >= 2:
                        alarma = True
                        print("Muchos intentos de forzar ALARMA ACTIVADA")
                        energia -= 20 
                        tiempo -= 2
                    else:
                        cerraduras_abiertas += 1
                        energia -= 20 
                        tiempo -= 2
                        forzar_seguidas += 1 
                case 2:
                    for i in range(1,5):
                        print(f"Paso {i}...")
                        codigo_parcial += random.choice("ABCDEFGHIJKLMNOPQRSTUVWXYZ")
                        print(codigo_parcial)
                    if len(codigo_parcial) >= 8 and cerraduras_abiertas < 3:
                        cerraduras_abiertas += 1
                    energia -= 10
                    tiempo -= 3
                    forzar_seguidas = 0
                case 3 :
                    tiempo -= 1
                    energia = min(energia + 15, 100)
                    if alarma == True:
                        energia -= 10
                    forzar_seguidas = 0
        else:
            print("Error: Introduzca una opcion entre el 1 y el 3")
    else:
        print("Error: Solo se aceptan numeros")

